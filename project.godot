; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="type-tactics"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GUIDE="*uid://p2jwrgjcbexr"
UnlockableContent="*uid://p3ilsmea4pp7"
GameManager="*uid://or5hd5dlt0kq"
GameSettings="*uid://cowb0y3ulunmj"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={}
directories/dtl_directory={}
layout/style_directory={
"dialogic_style_mon": "res://ui/dialogic_style_mon.tres",
"dialogic_style_vn": "res://ui/dialogic_style_vn.tres"
}
layout/style_list=["res://ui/dialogic_style_mon.tres", "res://ui/dialogic_style_vn.tres"]
layout/default_style=""

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/minimize_disabled=true

[dotnet]

project/assembly_name="type-tactics"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/grid_attack_pattern_editor/plugin.cfg", "res://addons/guide/plugin.cfg", "res://addons/scene_reference/plugin.cfg", "res://addons/unlockable_content/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://data/": "pink",
"res://entities/": "teal",
"res://globals/": "purple",
"res://scripts/": "blue",
"res://texture/": "orange",
"res://ui/": "green",
"res://world/": "yellow"
}

